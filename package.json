{
  "name": "react-node-insim-app-template",
  "version": "0.0.0",
  "main": "dist/index.cjs",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.tsx",
    "serve:production": "node ./dist/index.cjs",
    "build": "tsup-node src/index.tsx --dts",
    "format": "prettier --write \"./**/*.{js,ts,tsx,md,json,yml,yaml}\"",
    "lint": "eslint \"./src/**/*\" --ext .js,.ts",
    "lint:fix": "eslint \"./src/**/*\" --ext .js,.ts --fix",
    "test": "run-s test:compile \"test:run {@}\" --",
    "test:compile": "tsc -p tsconfig.test.json",
    "test:run": "vitest"
  },
  "dependencies": {
    "debug": "^4.4.1",
    "dotenv": "^17.2.1",
    "node-insim": "^5.0.0",
    "react": "^18.3.1",
    "react-node-insim": "0.2.0",
    "supports-color": "^10.2.0"
  },
  "devDependencies": {
    "@types/debug": "^4.1.12",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@typescript-eslint/eslint-plugin": "^8.40.0",
    "@typescript-eslint/parser": "^8.40.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.6.2",
    "tsup": "^8.5.0",
    "tsx": "^4.20.4",
    "typescript": "^5.9.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "files": [
    "**/*.js",
    "**/*.d.ts"
  ],
  "packageManager": "pnpm@10.14.0+sha512.ad27a79641b49c3e481a16a805baa71817a04bbe06a38d17e60e2eaee83f6a146c6a688125f5792e48dd5ba30e7da52a5cda4c3992b9ccf333f9ce223af84748"
}
